R2_PUBLIC_URL=https://img.moruzzi.it
R2_PRODUCT_FOLDER=prodotti

CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
# Host usato per la purge CDN dopo upload immagini prodotto (default: R2_PUBLIC_URL)
# CLOUDFLARE_PUBLIC_IMAGE_HOST=https://img.moruzzi.it

DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_ACCESS_TOKEN=
