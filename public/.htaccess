<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # /h/ immagini — locale se presente, altrimenti redirect a R2 CDN (gli HTML restano sul sito)
    RewriteCond %{REQUEST_URI} ^/h/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^h/(.+\.(jpe?g|png|gif|webp|svg|bmp|ico))$ https://img.moruzzi.it/h/$1 [R=301,L,NC]

    # Scorciatoia pannello amministrazione: /amministrazione.html -> /admin/amministrazione.html
    RewriteRule ^amministrazione\.html$ /admin/amministrazione.html [R=301,L]

    # Product detail URLs: route to Laravel without filesystem lookup (long slugs exceed NAME_MAX)
    RewriteRule ^(?:(?:en|fr|de|es)/)?.+-[0-9]+\.html$ index.php [L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
